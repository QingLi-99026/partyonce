# ============================================
# PartyOnce 前端环境变量配置模板
# ============================================
# 复制此文件为 .env.local（开发）或 .env.production（生产）
# ============================================

# --------------------------------------------
# API 配置（必需）
# --------------------------------------------

# 后端 API 基础 URL
# 开发环境: http://localhost:8000
# 生产环境: https://partymaster-api.render.com
VUE_APP_API_URL=http://localhost:8000

# --------------------------------------------
# R2 对象存储配置（必需）
# --------------------------------------------

# R2 公共访问 URL（用于显示上传的文件）
# 格式: https://pub-<account-id>.r2.dev 或你的自定义域名
VUE_APP_R2_PUBLIC_URL=https://pub-your-account-id.r2.dev

# --------------------------------------------
# 应用配置（可选）
# --------------------------------------------

# 应用名称
VUE_APP_NAME=PartyOnce

# 应用版本
VUE_APP_VERSION=1.0.0

# 环境标识: development | production
VUE_APP_ENV=development

# --------------------------------------------
# 功能开关（可选）
# --------------------------------------------

# 是否启用 AI 策划功能
true | false
VUE_APP_ENABLE_AI=true

# 是否启用 3D 设计功能
true | false
VUE_APP_ENABLE_3D=true

# 是否启用实时协作（如实现）
VUE_APP_ENABLE_COLLABORATION=false

# --------------------------------------------
# 第三方服务（可选）
# --------------------------------------------

# Google Maps API Key（如使用地图功能）
VUE_APP_GOOGLE_MAPS_API_KEY=

# Sentry DSN（错误追踪）
VUE_APP_SENTRY_DSN=

# 分析工具 ID（如 Google Analytics）
VUE_APP_ANALYTICS_ID=

# ============================================
# 注意事项
# ============================================
# 1. 所有 VUE_APP_ 前缀的变量都可以在代码中通过 process.env.VUE_APP_XXX 访问
# 2. 修改环境变量后需要重新启动开发服务器或重新构建
# 3. .env.local 文件不会被提交到 Git（已添加到 .gitignore）
# 4. 生产环境变量在构建时注入，运行时不能更改
# ============================================
