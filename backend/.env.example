# ============================================
# PartyOnce 后端环境变量配置模板
# ============================================
# 复制此文件为 .env 并填入实际值
# 警告：.env 文件包含敏感信息，不要提交到 Git！
# ============================================

# --------------------------------------------
# 应用基础配置（必需）
# --------------------------------------------

# 运行环境: development | production
ENVIRONMENT=development

# 调试模式: true | false
DEBUG=true

# 服务端口（Render/Railway 会自动设置 PORT）
PORT=8000

# --------------------------------------------
# 数据库配置（必需）
# --------------------------------------------

# MySQL 数据库连接字符串
# 格式: mysql+pymysql://username:password@host:port/database
# Railway MySQL 示例:
# DATABASE_URL=mysql+pymysql://root:password@containers.railway.app:3306/railway
# PlanetScale 示例:
# DATABASE_URL=mysql+pymysql://username:password@host/database?ssl_ca=/etc/ssl/cert.pem
DATABASE_URL=mysql+pymysql://root:@localhost/partyonce

# --------------------------------------------
# JWT 安全配置（必需）
# --------------------------------------------

# JWT 密钥（生产环境必须更改！至少 32 个字符）
# 生成命令: openssl rand -hex 32
SECRET_KEY=your-super-secret-jwt-key-min-32-characters-change-in-production

# JWT 算法
ALGORITHM=HS256

# Token 过期时间（分钟）
ACCESS_TOKEN_EXPIRE_MINUTES=30

# --------------------------------------------
# OpenAI API（AI 策划功能必需）
# --------------------------------------------

# OpenAI API Key（从 https://platform.openai.com/api-keys 获取）
OPENAI_API_KEY=sk-your-openai-api-key-here

# --------------------------------------------
# Cloudflare R2 对象存储（文件上传必需）
# --------------------------------------------

# R2 Endpoint URL（从 Cloudflare Dashboard 获取）
# 格式: https://<account-id>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://your-account-id.r2.cloudflarestorage.com

# R2 Access Key ID（创建 API Token 时生成）
R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 Secret Access Key（创建 API Token 时生成）
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 Bucket 名称
R2_BUCKET_NAME=partymaster-uploads

# R2 公共访问 URL
# 格式: https://pub-<account-id>.r2.dev 或你的自定义域名
R2_PUBLIC_URL=https://pub-your-account-id.r2.dev

# --------------------------------------------
# Redis 缓存（可选）
# --------------------------------------------

# Redis 连接字符串（Upstash 或其他 Redis 服务）
# 格式: rediss://default:password@host:port
REDIS_URL=

# 缓存 TTL（秒）
REDIS_CACHE_TTL=3600

# --------------------------------------------
# 邮件服务（可选，用于发送报价邮件）
# --------------------------------------------

# SMTP 服务器配置
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Gmail 需要使用应用专用密码
SMTP_PASSWORD=your-app-password

# 发件人邮箱
FROM_EMAIL=PartyOnce <noreply@partymaster.app>

# --------------------------------------------
# 错误追踪（可选）
# --------------------------------------------

# Sentry DSN（从 https://sentry.io 获取）
SENTRY_DSN=https://xxx@yyy.ingest.sentry.io/zzz

# --------------------------------------------
# 其他配置
# --------------------------------------------

# 允许的前端域名（CORS，逗号分隔）
# 示例: https://app.partymaster.app,https://partyonce.vercel.app
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# 日志级别: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# 时区
TZ=UTC

# ============================================
# 部署检查清单
# ============================================
# [ ] 已更改 SECRET_KEY（生产环境）
# [ ] 已配置正确的 DATABASE_URL
# [ ] 已配置 OpenAI API Key
# [ ] 已配置所有 R2 环境变量
# [ ] 已配置 CORS 允许的前端域名
# [ ] 已验证文件上传功能
# [ ] 已删除或保护此 .env 文件
# ============================================
