# PartyOnce 本地 Staging 部署配置
# 更新时间: 2026-03-04

# ============================================
# 数据库配置 (本地 Docker)
# ============================================
DB_ROOT_PASSWORD=PartyOnce2026!
DB_NAME=partyonce
DB_USER=partyonce
DB_PASSWORD=partyonce_staging_2026

# ============================================
# 数据库连接URL (Docker内部网络)
# ============================================
DATABASE_URL=mysql+pymysql://partyonce:partyonce_staging_2026@db:3306/partyonce

# ============================================
# JWT安全
# ============================================
SECRET_KEY=partyonce-staging-secret-key-2026-03-04-moses-deploy

# ============================================
# Cloudflare R2 对象存储 (暂时用占位符，本地测试可不填)
# ============================================
R2_ENDPOINT_URL=https://your-account.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=placeholder
R2_SECRET_ACCESS_KEY=placeholder
R2_BUCKET_NAME=partyonce-staging
R2_PUBLIC_URL=https://pub-your-account.r2.dev

# ============================================
# OpenAI API (可选，AI策划功能)
# ============================================
OPENAI_API_KEY=sk-placeholder

# ============================================
# 其他配置
# ============================================
ENVIRONMENT=staging
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:8000
LOG_LEVEL=INFO
